# Copy this file to `.env.local` (same folder) and fill in the value.
# `.env.local` is gitignored — never commit a real key.
#
# Server-side ONLY: used by the /api/generate/* Route Handlers. It is never
# exposed to the browser (the editor calls our proxy, not Anthropic directly).
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Postgres (Vercel Marketplace → Neon). OPTIONAL for local dev: if unset, the app
# uses an in-memory repository (data resets on restart). Set it to use real
# Postgres locally, and run `npm run db:migrate -w @proposal/web` once to create
# the tables. On Vercel, the Neon integration provides this automatically.
#
# NOTE: on Vercel, the PDF export function and the /print route are separate
# invocations, so they can only share a proposal through Postgres. DATABASE_URL
# is therefore REQUIRED for export to work in production (in-memory won't do).
# It is ALSO required for sign-in: accounts live in the `users` table, so set
# DATABASE_URL locally (and run `npm run db:migrate -w @proposal/web`) to log in.
DATABASE_URL=

# --- Auth (§13.10) -----------------------------------------------------------
# Auth.js session-signing secret. Generate one with: npx auth secret
# (or `openssl rand -base64 32`). Also signs the short-lived /print render token.
AUTH_SECRET=

# Accounts are DB-backed and ADMIN-CREATED (no public signup). Bootstrap the first
# admin from the CLI, then create others from the Builder dashboard:
#   npm run user:create -w @proposal/web -- --admin you@example.com "your-password"
# Passwords are scrypt-hashed before they're stored; nothing is kept in plaintext.

# Accounts are managed from the Builder dashboard (/admin → Users): create, disable/
# enable, promote/demote, and reset passwords. NOTE: sessions are stateless JWTs, so
# disabling or demoting a user takes effect at their NEXT sign-in — a live session
# keeps its token until it expires.

# Vercel Blob (logo/image uploads via /api/assets). Provided automatically when
# you add a Blob store to the project on Vercel; set locally to test uploads.
BLOB_READ_WRITE_TOKEN=
