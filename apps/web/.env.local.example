# Copy this file to `.env.local` (same folder) and fill in the values.
# `.env.local` is gitignored — never commit real secrets.
#
# What each feature needs:
#   Sign in / accounts / saving / export ... DATABASE_URL + AUTH_SECRET   (REQUIRED)
#   AI draft + regenerate .................. ANTHROPIC_API_KEY
#   Logo / image uploads .................. BLOB_READ_WRITE_TOKEN
#   PDF export, LOCAL dev ................. PUPPETEER_EXECUTABLE_PATH
#   PDF export, on Vercel ................. nothing extra (CHROMIUM_PACK_URL optional)
#
# How this file is loaded:
#   - `next dev` and `npm run user:create` auto-load it.
#   - `drizzle-kit` (db:migrate / db:generate) does NOT — pass DATABASE_URL in the
#     shell for those, e.g. (PowerShell):
#       $env:DATABASE_URL = "postgresql://...sslmode=require"; npm run db:migrate -w @proposal/web
#   - On Vercel these live as Environment Variables; the Neon + Blob integrations
#     inject DATABASE_URL / BLOB_READ_WRITE_TOKEN automatically. `vercel env pull`
#     can bring them down into this file for local use (it OVERWRITES this file).

# --- Database — REQUIRED (sign-in, saving, export) ---------------------------
# Postgres via Neon. Sign-in reads the `users` table; without this the app falls
# back to an in-memory repo that has NO users, so every sign-in fails. Use the
# Neon connection string and include `?sslmode=require`. Run migrations once:
#   npm run db:migrate -w @proposal/web   (with DATABASE_URL exported in the shell)
DATABASE_URL=

# --- Auth — REQUIRED (sign-in) ----------------------------------------------
# Auth.js (next-auth) secret. Signs/encrypts the JWT session cookie AND the
# short-lived /print render token used during PDF export. Generate one with:
#   npx auth secret        (writes it here)   — or —   openssl rand -base64 32
# Rotating it signs everyone out. Set a value in every environment.
AUTH_SECRET=

# --- Anthropic — AI generation ----------------------------------------------
# Server-side ONLY (the browser calls our proxy, never Anthropic directly).
# Needed for Generate / Regenerate. Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Vercel Blob — logo / image uploads -------------------------------------
# Needed only for asset uploads via /api/assets. On Vercel, adding a Blob store
# injects this automatically; set it locally only to test uploads.
BLOB_READ_WRITE_TOKEN=

# --- PDF export: local Chrome (LOCAL dev only) ------------------------------
# Locally, PDF export needs a real Chrome/Chromium binary. UNUSED on Vercel
# (it uses @sparticuz/chromium-min automatically). Example (Windows):
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# --- PDF export: Chromium pack override (optional) --------------------------
# Override the serverless Chromium "pack" tar URL (defaults to a GitHub release).
# Only set this to self-host the pack for reliability.
# CHROMIUM_PACK_URL=

# --- Accounts (reference) ----------------------------------------------------
# DB-backed and ADMIN-CREATED (no public signup). Bootstrap the first admin:
#   npm run user:create -w @proposal/web -- --admin you@example.com "your-password"
# Then manage others from the Builder dashboard (/admin → Users): create, disable/
# enable, promote/demote, reset passwords. Passwords are scrypt-hashed at rest.
# NOTE: sessions are stateless JWTs — disabling/demoting a user takes effect at
# their NEXT sign-in; a live session keeps its token until it expires.
